# ====== Baza danych (Neon Postgres — Vercel Marketplace) ======
DATABASE_URL=
# Opcjonalnie — bez poolera (migracje CLI)
DATABASE_URL_UNPOOLED=

# Jednorazowa migracja z Sanity (pnpm migrate:sanity) — opcjonalnie
NEXT_PUBLIC_SANITY_PROJECT_ID=sqgw0wlq
NEXT_PUBLIC_SANITY_DATASET=production

# ====== Email (Resend) ======
RESEND_API_KEY=

# ====== Google Calendar (Workspace, z domain-wide delegation) ======
# Service account z GCP:
GOOGLE_CLIENT_EMAIL=booking-service@your-project.iam.gserviceaccount.com
# Klucz prywatny — CAŁY, z "\n" zamiast realnych newlinów
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Kogo impersonujemy (musi być userem w Twojej domenie Workspace)
GOOGLE_CALENDAR_USER=kamil@syntance.com
# Na który kalendarz piszemy (zwykle "primary")
GOOGLE_CALENDAR_ID=primary

# ====== Dashboard /magazyn ======
ADMIN_EMAIL=kamil@syntance.com
ADMIN_PASSWORD=Fv215b0108
# WYGENERUJ: openssl rand -hex 32
ADMIN_COOKIE_SECRET=

# ====== Publiczny URL strony ======
NEXT_PUBLIC_SITE_URL=https://syntance.com

# ====== PostHog (EU Cloud) ======
# Project token z PostHog → Settings → Project → Project API key
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Publiczne IP-y wykluczone z trackingu (po przecinku). Sprawdź: curl ifconfig.me
POSTHOG_INTERNAL_IPS=

# ====== CRM (Attio) — opcjonalne ======
ATTIO_API_KEY=
# Webhook (HMAC w nagłówku Attio-Signature)
ATTIO_WEBHOOK_SECRET=
# Dedupe maili etapowych / cooldown przypomnień (bez tego — wysyłka bez blokady)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Opcjonalnie: inna kolumna etapu na liście niż natywny stage (UUID po przecinku)
# ATTIO_LIST_STAGE_ATTRIBUTE_IDS=
# Ręczne „Wyślij przypomnienie” — select na dealu (slug + UUID z API / payloadu webhooka)
# ATTIO_REMINDER_EMAIL_ATTRIBUTE_SLUG=email_reminder
ATTIO_REMINDER_EMAIL_ATTRIBUTE_ID=
# ATTIO_REMINDER_LIST_ATTRIBUTE_IDS=  # dodatkowe UUID tej samej kolumny na innych listach
# ATTIO_REMINDER_EMAIL_TRIGGER_TITLE=Wyślij przypomnienie
# Opcja „Brak” po wysyłce (UUID opcji select w Attio)
# ATTIO_REMINDER_EMAIL_IDLE_OPTION_ID=
# ATTIO_REMINDER_COOLDOWN_HOURS=24
